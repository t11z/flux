{
  "$comment": "flux Panorama XML-API schema - curated from constraint probing + fixtures. Single source of truth for validate_config.py.",
  "target": "panorama",
  "panosVersion": "12.1.2",
  "api": "xml",
  "deviceXPathRoot": "/config/devices/entry[@name='localhost.localdomain']",
  "note": "containers are predicate-stripped (no [@name=...]). 'set' enforces enums/format/unknown elements but NOT required/choice - flux checks those itself. choice (oneOf): zero=error, more-than-one=warning (PAN-OS keeps one).",
  "formats": {
    "ip-netmask": "IPv4/IPv6, optional /prefix",
    "ip-range": "IP-IP",
    "fqdn": "DNS name",
    "port-spec": "port 1-65535, range a-b or list a,b (no 0 / >65535)"
  },
  "resources": {
    "address": {
      "containers": [
        "/config/shared/address",
        "/config/devices/entry/device-group/entry/address"
      ],
      "allowedChildren": [
        "ip-netmask",
        "ip-range",
        "ip-wildcard",
        "fqdn",
        "description",
        "tag",
        "disable-override"
      ],
      "oneOf": [
        [
          "ip-netmask",
          "ip-range",
          "ip-wildcard",
          "fqdn"
        ]
      ],
      "formats": {
        "ip-netmask": "ip-netmask",
        "ip-range": "ip-range",
        "fqdn": "fqdn"
      },
      "memberlists": [
        "tag"
      ],
      "required": []
    },
    "service": {
      "containers": [
        "/config/shared/service",
        "/config/devices/entry/device-group/entry/service"
      ],
      "allowedChildren": [
        "protocol",
        "description",
        "tag"
      ],
      "required": [
        "protocol"
      ],
      "memberlists": [
        "tag"
      ],
      "nested": {
        "protocol": {
          "allowedChildren": [
            "tcp",
            "udp",
            "sctp"
          ],
          "oneOf": [
            [
              "tcp",
              "udp",
              "sctp"
            ]
          ],
          "nested": {
            "tcp": {
              "allowedChildren": [
                "port",
                "source-port",
                "override"
              ],
              "required": [
                "port"
              ],
              "formats": {
                "port": "port-spec",
                "source-port": "port-spec"
              }
            },
            "udp": {
              "allowedChildren": [
                "port",
                "source-port",
                "override"
              ],
              "required": [
                "port"
              ],
              "formats": {
                "port": "port-spec",
                "source-port": "port-spec"
              }
            },
            "sctp": {
              "allowedChildren": [
                "port",
                "source-port"
              ],
              "required": [
                "port"
              ],
              "formats": {
                "port": "port-spec",
                "source-port": "port-spec"
              }
            }
          }
        }
      }
    },
    "address-group": {
      "containers": [
        "/config/shared/address-group",
        "/config/devices/entry/device-group/entry/address-group"
      ],
      "allowedChildren": [
        "static",
        "dynamic",
        "description",
        "tag"
      ],
      "oneOf": [
        [
          "static",
          "dynamic"
        ]
      ],
      "memberlists": [
        "static",
        "tag"
      ],
      "nested": {
        "dynamic": {
          "allowedChildren": [
            "filter"
          ],
          "required": [
            "filter"
          ]
        }
      }
    },
    "security-rule": {
      "containers": [
        "/config/devices/entry/device-group/entry/pre-rulebase/security/rules",
        "/config/devices/entry/device-group/entry/post-rulebase/security/rules"
      ],
      "allowedChildren": [
        "from",
        "to",
        "source",
        "destination",
        "source-user",
        "application",
        "service",
        "category",
        "action",
        "description",
        "disabled",
        "log-start",
        "log-end",
        "log-setting",
        "rule-type",
        "tag",
        "negate-source",
        "negate-destination",
        "profile-setting",
        "hip-profiles",
        "uuid"
      ],
      "required": [
        "from",
        "to",
        "source",
        "destination",
        "application",
        "service",
        "action"
      ],
      "memberlists": [
        "from",
        "to",
        "source",
        "destination",
        "source-user",
        "application",
        "service",
        "category",
        "tag",
        "hip-profiles"
      ],
      "enums": {
        "action": [
          "allow",
          "deny",
          "drop",
          "reset-client",
          "reset-server",
          "reset-both"
        ],
        "disabled": [
          "yes",
          "no"
        ],
        "log-start": [
          "yes",
          "no"
        ],
        "log-end": [
          "yes",
          "no"
        ],
        "rule-type": [
          "universal",
          "intrazone",
          "interzone"
        ],
        "negate-source": [
          "yes",
          "no"
        ],
        "negate-destination": [
          "yes",
          "no"
        ]
      }
    },
    "device-group": {
      "containers": [
        "/config/devices/entry/device-group"
      ],
      "allowedChildren": [
        "description",
        "address",
        "address-group",
        "service",
        "service-group",
        "tag",
        "pre-rulebase",
        "post-rulebase",
        "devices",
        "reference-templates"
      ],
      "required": []
    },
    "template": {
      "containers": [
        "/config/devices/entry/template"
      ],
      "allowedChildren": [
        "description",
        "config",
        "settings",
        "variable"
      ],
      "required": []
    },
    "template-stack": {
      "containers": [
        "/config/devices/entry/template-stack"
      ],
      "allowedChildren": [
        "templates",
        "description",
        "devices",
        "settings",
        "variable"
      ],
      "required": [
        "templates",
        "settings"
      ],
      "memberlists": [
        "templates",
        "devices"
      ]
    },
    "ethernet-interface": {
      "containers": [
        "/config/devices/entry/template/entry/config/devices/entry/network/interface/ethernet"
      ],
      "allowedChildren": [
        "layer3",
        "layer2",
        "tap",
        "virtual-wire",
        "ha",
        "decrypt-mirror",
        "aggregate-group",
        "comment",
        "link-state",
        "link-speed",
        "link-duplex",
        "mtu",
        "netflow-profile",
        "poe"
      ],
      "required": [],
      "nested": {
        "layer3": {
          "allowedChildren": [
            "ip",
            "interface-management-profile",
            "mtu",
            "adjust-tcp-mss",
            "units",
            "ipv6",
            "dhcp-client",
            "arp",
            "ndp-proxy",
            "lldp",
            "netflow-profile"
          ]
        }
      }
    },
    "zone": {
      "containers": [
        "/config/devices/entry/template/entry/config/devices/entry/vsys/entry/zone"
      ],
      "allowedChildren": [
        "network",
        "enable-user-identification",
        "user-acl",
        "log-setting",
        "enable-device-identification"
      ],
      "required": [],
      "nested": {
        "network": {
          "allowedChildren": [
            "layer3",
            "layer2",
            "virtual-wire",
            "tap",
            "external",
            "tunnel",
            "zone-protection-profile",
            "enable-packet-buffer-protection",
            "log-setting"
          ],
          "memberlists": [
            "layer3",
            "layer2",
            "virtual-wire",
            "tap",
            "external"
          ]
        }
      }
    },
    "virtual-router": {
      "containers": [
        "/config/devices/entry/template/entry/config/devices/entry/network/virtual-router"
      ],
      "allowedChildren": [
        "interface",
        "routing-table",
        "protocol",
        "ecmp",
        "admin-dists",
        "multicast"
      ],
      "memberlists": [
        "interface"
      ],
      "required": []
    },
    "nat-rule": {
      "containers": [
        "/config/devices/entry/device-group/entry/pre-rulebase/nat/rules",
        "/config/devices/entry/device-group/entry/post-rulebase/nat/rules"
      ],
      "allowedChildren": [
        "from",
        "to",
        "source",
        "destination",
        "service",
        "nat-type",
        "source-translation",
        "destination-translation",
        "to-interface",
        "active-active-device-binding",
        "disabled",
        "description",
        "tag",
        "group-tag",
        "uuid",
        "target",
        "negate-target"
      ],
      "required": [
        "from",
        "to",
        "source",
        "destination",
        "service"
      ],
      "memberlists": [
        "from",
        "to",
        "source",
        "destination",
        "tag"
      ],
      "enums": {
        "nat-type": [
          "ipv4",
          "nat64",
          "nptv6"
        ],
        "disabled": [
          "yes",
          "no"
        ]
      }
    }
  }
}
